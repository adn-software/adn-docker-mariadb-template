# Configuración del Contenedor
CONTAINER_NAME=mariadb-client-001
VOLUME_NAME=mariadb_client_001_data
NETWORK_NAME=mariadb_client_001_network

# Configuración de MariaDB
MYSQL_ROOT_PASSWORD=root_secure_password_change_me
MYSQL_DATABASE=sistemasadn
MYSQL_USER=sistemas
MYSQL_PASSWORD=adn

# Puerto de acceso externo
# Nota: Si tienes MySQL/MariaDB instalado localmente, usa un puerto diferente (ej: 3307)
MYSQL_PORT=3307

# Zona horaria
TIMEZONE=America/Caracas

# ═══════════════════════════════════════════════════════════════
# CONFIGURACIÓN DE TAREAS AUTOMÁTICAS (CRON)
# ═══════════════════════════════════════════════════════════════
# Formato cron: minuto hora día-mes mes día-semana
# Ejemplos:
#   "0 2 * * *"     = Todos los días a las 2:00 AM
#   "0 */6 * * *"   = Cada 6 horas
#   "0 0,12 * * *"  = Dos veces al día (medianoche y mediodía)
#   "0 3 * * 0"     = Cada domingo a las 3:00 AM
# ═══════════════════════════════════════════════════════════════

# Backup automático (backup-complete.sh: todas las BDs + Wasabi + Notificación)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *

# Health check y reparación automática (health-check-complete.sh: todas las BDs + Reparación + Notificación)
HEALTH_CHECK_ENABLED=true
HEALTH_SCHEDULE=0 */6 * * *

# ═══════════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL SISTEMA DE MONITOREO ADN
# ═══════════════════════════════════════════════════════════════
# URL base del API del sistema de monitoreo
MONITOR_API_URL=https://api.adnsistemas.com/api/v1

# API Key del servidor de base de datos (obtenida al crear el Database Server)
MONITOR_API_KEY=sk_live_CAMBIAR_POR_TU_API_KEY

# UUID del servidor de base de datos en el sistema (obtenido al crear el Database Server)
MONITOR_SERVER_ID=CAMBIAR_POR_TU_SERVER_UUID

# UUID de la base de datos específica en el sistema (obtenido después de sincronizar)
MONITOR_DATABASE_ID=CAMBIAR_POR_TU_DATABASE_UUID
