# ═══════════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL SISTEMA DE MONITOREO ADN
# ═══════════════════════════════════════════════════════════════
# Este archivo debe ser copiado a /etc/monitor.env dentro del contenedor
# y editado con los valores correctos obtenidos del sistema de monitoreo.
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# 1. CONFIGURACIÓN DEL API DEL SISTEMA DE MONITOREO
# ───────────────────────────────────────────────────────────────

# URL base del API del sistema de monitoreo
# Producción: https://api.adnsistemas.com/api/v1
# Desarrollo: http://localhost:3000/api/v1
MONITOR_API_URL=https://api.adnsistemas.com/api/v1

# API Key del servidor de base de datos
# Obtenida al crear el Database Server en el sistema
# Formato: sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONITOR_API_KEY=sk_live_CAMBIAR_POR_TU_API_KEY

# UUID del servidor de base de datos en el sistema
# Obtenido al crear el Database Server
# Formato: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MONITOR_SERVER_ID=CAMBIAR_POR_TU_SERVER_UUID

# UUID de la base de datos específica en el sistema
# Obtenido después de sincronizar las bases de datos
# Formato: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MONITOR_DATABASE_ID=CAMBIAR_POR_TU_DATABASE_UUID

# ───────────────────────────────────────────────────────────────
# 2. CONFIGURACIÓN DE BACKUPS
# ───────────────────────────────────────────────────────────────

# Directorio donde se almacenarán los backups
BACKUP_DIR=/backups

# Días de retención de backups (backups más antiguos serán eliminados)
BACKUP_RETENTION_DAYS=7

# ───────────────────────────────────────────────────────────────
# 3. CONFIGURACIÓN DE CONEXIÓN A MARIADB
# ───────────────────────────────────────────────────────────────

# Host de MariaDB (normalmente localhost dentro del contenedor)
DB_HOST=localhost

# Puerto de MariaDB
DB_PORT=3306

# ───────────────────────────────────────────────────────────────
# NOTAS IMPORTANTES
# ───────────────────────────────────────────────────────────────
# 
# 1. MYSQL_ROOT_PASSWORD debe estar ya configurado como variable
#    de entorno del contenedor. No es necesario definirla aquí.
#
# 2. Para obtener las credenciales del sistema de monitoreo:
#    a) Crear Database Server: POST /database-servers
#    b) Sincronizar bases de datos: POST /database-sync/sync
#    c) Obtener IDs de la respuesta
#
# 3. Ejemplo de cómo obtener los IDs:
#    curl -X POST https://api.adnsistemas.com/api/v1/database-servers \
#      -H "Authorization: Bearer <JWT_TOKEN>" \
#      -H "Content-Type: application/json" \
#      -d '{
#        "name": "MariaDB Container - Cliente ABC",
#        "engine": "mariadb",
#        "host": "192.168.1.100",
#        "port": 3306,
#        "username": "root",
#        "password": "password",
#        "monitoringEnabled": true,
#        "backupEnabled": true
#      }'
#
# 4. Para probar la configuración:
#    source /etc/monitor.env
#    echo "API URL: $MONITOR_API_URL"
#    echo "API Key: ${MONITOR_API_KEY:0:15}..."
#    echo "Server ID: $MONITOR_SERVER_ID"
#    echo "Database ID: $MONITOR_DATABASE_ID"
#
# ═══════════════════════════════════════════════════════════════
