[mysqld]
# ============================================
# CONFIGURACIÓN DE RED Y SISTEMA
# ============================================
bind-address = 0.0.0.0
skip-name-resolve
port = 3306

event_scheduler = ON

# Vital para migraciones desde Windows (mantiene compatibilidad de mayúsculas/minúsculas)
lower_case_table_names=1

# Desactiva telemetría para ahorrar ~400-600MB de RAM
performance_schema = OFF

# Desactiva logs binarios si no usas replicación/espejo (Ahorra disco e I/O)
skip-log-bin

# ============================================
# CONFIGURACIÓN DE CARACTERES
# ============================================
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# ============================================
# CONEXIONES
# ============================================
max_connections = 200
max_connect_errors = 100000
thread_cache_size = 16
table_open_cache = 1000   # Aumentado un poco para Linux
table_definition_cache = 600

# ============================================
# BUFFERS 
# ============================================
max_allowed_packet = 64M
sort_buffer_size = 2M
read_buffer_size = 1M
read_rnd_buffer_size = 2M
join_buffer_size = 2M
tmp_table_size = 64M
max_heap_table_size = 64M

# ============================================
# INNODB (El motor principal)
# ============================================
# Tu BD pesa 1.5GB. 2GB es el tamaño perfecto.
innodb_buffer_pool_size = 2G
innodb_buffer_pool_instances = 2

innodb_log_file_size = 256M # Aumentado ligeramente para mejor rendimiento en escrituras pesadas
innodb_log_buffer_size = 32M

# Rendimiento vs Seguridad (2 es rápido, ideal para VM)
innodb_flush_log_at_trx_commit = 2

# Optimización exclusiva para Linux (Evita doble caché en RAM)
innodb_flush_method = O_DIRECT

# --- OPTIMIZACIÓN NVMe ---
# Ajustado para tu disco rápido. 400 era muy poco.
innodb_io_capacity = 1000
innodb_io_capacity_max = 4000

innodb_read_io_threads = 4
innodb_write_io_threads = 4
innodb_thread_concurrency = 0

innodb_file_per_table = 1
innodb_lock_wait_timeout = 50
innodb_rollback_on_timeout = 1

# ============================================
# LOGS
# ============================================
general_log = 0
slow_query_log = 1
slow_query_log_file = /var/lib/mysql/slow-query.log
long_query_time = 10
log_queries_not_using_indexes = 0
log_error = /var/lib/mysql/error.log
log_warnings = 2

# ============================================
# SEGURIDAD
# ============================================
local_infile = 0
symbolic-links = 0

# ============================================
# TIMEOUTS
# ============================================
wait_timeout = 600
interactive_timeout = 600
connect_timeout = 10

# ============================================
# CLIENTE
# ============================================
[client]
default-character-set = latin1
port = 3306

[mysql]
default-character-set = latin1